{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedOrigin": "http://localhost:3000",
  "AllowedHosts": "*",
  "OpenSky": {
    "TokenUrl": "https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token",
    "ApiBaseUrl": "https://opensky-network.org"
  },
  "Adsbdb": {
    "ApiBaseUrl": "https://api.adsbdb.com"
  },
  "Ingestion": {
    "MinLon": 4.0,
    "MaxLon": 32.0,
    "MinLat": 54.0,
    "MaxLat": 72.0,
    "PollIntervalSeconds": 120,
    "GapThresholdSeconds": 360,
    "MinPointIntervalSeconds": 30,
    "MaxTrackPoints": 300
  },
  "Enrichment": {
    "RunAtHourUtc": 4,
    "MinAgeMinutes": 240,
    "MaxAttempts": 3,
    "MaxLookbackDays": 2,
    "WindowHours": 2
  },
  "Retention": {
    "Enabled": true,
    "RetentionDays": 15,
    "RunAtHourUtc": 6,
    "BatchSize": 5000,
    "DelayBetweenBatchesMs": 500
  }
}
